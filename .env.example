# Public base URL used for canonical links, Open Graph and the sitemap.
NEXT_PUBLIC_SITE_URL=https://conroy.global

# Base URL for the backend API (Express + Supabase). When the backend is
# running, set this to its /api path so the catalog, forms and checkout use it.
# Falls back gracefully to the bundled data + Next route handlers if unset/offline.
#   Local backend:  http://localhost:4000/api
#   Default:        /api  (the in-app Next.js route handlers)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# ── Supabase (login / phone auth, client-side) ───────────────────────────────
# Public values from Supabase → Project Settings → API. Unset = demo mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Payments (Razorpay) ──────────────────────────────────────────────────────
# From Razorpay dashboard → Settings → API Keys (use TEST keys for free dev).
# Unset = demo mode: Cash on Delivery + a simulated online payment (no charge).
NEXT_PUBLIC_RAZORPAY_KEY_ID=

