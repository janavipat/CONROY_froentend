# ─────────────────────────────────────────────────────────────
# CONROY backend environment
# Copy to ".env" and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────

# Project URL, e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL=

# "anon / public" key — safe for clients, respects Row Level Security.
SUPABASE_ANON_KEY=

# "service_role" key — SECRET. Bypasses RLS. Server-side only, never expose.
SUPABASE_SERVICE_ROLE_KEY=

# API server
PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API (the frontend).
CORS_ORIGINS=http://localhost:3000

# Phone OTP login. Mock mode = no real SMS; sign in with OTP_TEST_CODE.
# Set OTP_MOCK=false (and configure a Supabase SMS provider) for real SMS.
OTP_MOCK=true
OTP_TEST_CODE=123456
OTP_DEFAULT_COUNTRY_CODE=+91

# MSG91 OTP (real SMS). From MSG91 dashboard. Keep OTP_MOCK=true until these are
# set + your DLT template is approved, then set OTP_MOCK=false.
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_LENGTH=6
MSG91_OTP_EXPIRY_MIN=10

# SMTP for the welcome email. Unset → emails are logged (mock), not sent.
# Works with Gmail (app password), MSG91 SMTP, Brevo, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CONROY <no-reply@conroy.global>"
