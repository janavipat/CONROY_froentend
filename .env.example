# ─────────────────────────────────────────────────────────────
# CONROY backend environment
# Copy to ".env" and fill in the values from your Supabase project:
#   Supabase Dashboard → Project Settings → API
# ─────────────────────────────────────────────────────────────

# Project URL, e.g. https://abcdefghijklmno.supabase.co
SUPABASE_URL=

# "anon / public" key — safe for clients, respects Row Level Security.
SUPABASE_ANON_KEY=

# "service_role" key — SECRET. Bypasses RLS. Server-side only, never expose.
SUPABASE_SERVICE_ROLE_KEY=

# API server
PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API (the frontend).
CORS_ORIGINS=http://localhost:3000

# Phone OTP login. Mock mode = no real SMS; sign in with OTP_TEST_CODE.
# Set OTP_MOCK=false (and configure a Supabase SMS provider) for real SMS.
OTP_MOCK=true
OTP_TEST_CODE=123456
OTP_DEFAULT_COUNTRY_CODE=+91

# WhatsApp Cloud API OTP (sends the code on WhatsApp from your Business number —
# NO SMS, so NO India DLT needed; free ~1,000 conversations/month). Get these
# from Meta → developers.facebook.com → your App → WhatsApp → API Setup.
#   WHATSAPP_PHONE_NUMBER_ID — the sender number's ID (NOT the phone number).
#   WHATSAPP_ACCESS_TOKEN    — a permanent System User token (SECRET).
#   WHATSAPP_TEMPLATE_NAME   — an approved "Authentication" template's name.
#   WHATSAPP_TEMPLATE_LANG   — its language code, e.g. en_US.
#   WHATSAPP_OTP_BUTTON      — true if the template has a copy-code button (default).
# Set OTP_MOCK=false once these are filled in. Takes priority over Twilio/Supabase.
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TEMPLATE_NAME=
WHATSAPP_TEMPLATE_LANG=en_US
WHATSAPP_OTP_BUTTON=true

# Twilio OTP (real SMS, sent directly from the backend). From Twilio Console →
# Account → API keys & tokens. Set OTP_MOCK=false once these are filled in.
#   TWILIO_FROM  — a Twilio phone number you OWN (e.g. your trial number, +1…).
#                  A personal mobile number will NOT work as a sender (err 21606).
#   Alternatively set TWILIO_MESSAGING_SERVICE_SID (leave FROM blank) to send via
#   a Messaging Service — that service must have a number in its Sender Pool.
# Trial accounts can only deliver to numbers added under Verified Caller IDs, and
# delivery to Indian numbers may require DLT registration.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=

# MSG91 OTP (legacy — no longer used; kept for reference).
MSG91_AUTH_KEY=
MSG91_TEMPLATE_ID=
MSG91_OTP_LENGTH=6
MSG91_OTP_EXPIRY_MIN=10

# Razorpay online payments. From Razorpay Dashboard → Settings → API Keys.
# Both must be set for live checkout; if blank, checkout falls back to free
# demo mode (order is recorded, no real charge). KEY_SECRET is SECRET — never
# expose it to the frontend (the frontend only receives KEY_ID from the API).
# Use rzp_test_… keys while testing, rzp_live_… when you go live.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# SMTP for the welcome email. Unset → emails are logged (mock), not sent.
# Works with Gmail (app password), MSG91 SMTP, Brevo, etc.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CONROY <no-reply@conroy.global>"

# Admin panel key. Set a strong secret; enter it at /admin/login to manage the
# store. If left blank, the /admin API is OPEN (dev only).
ADMIN_KEY=
