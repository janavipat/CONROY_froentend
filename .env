# "anon / public" key — safe for clients, respects Row Level Security.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp2aXFyeWJlcmJqbXZwdXFjdW9iIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODIwMzUwNTksImV4cCI6MjA5NzYxMTA1OX0.xr3MurcRjU_AFZnH0NMRwrjlXj6Jw6EyA-Z3Wr5jOvc

# "service_role" key — SECRET. Bypasses RLS. Server-side only, never expose.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imp2aXFyeWJlcmJqbXZwdXFjdW9iIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MjAzNTA1OSwiZXhwIjoyMDk3NjExMDU5fQ.WwGfHFeR5eOKK4UqyZlAM_vB7t12SPT7hGuab-d59dc

# API server
PORT=4000
NODE_ENV=development

# Comma-separated list of origins allowed to call this API (the frontend).
CORS_ORIGINS=http://localhost:3000

# Phone OTP login. Mock mode = no real SMS; sign in with OTP_TEST_CODE.
# OTP_MOCK=false → real SMS via MSG91.
OTP_MOCK=false
OTP_TEST_CODE=123456
OTP_DEFAULT_COUNTRY_CODE=+91

# MSG91 OTP (real SMS).
MSG91_AUTH_KEY=546280AYO47eutw6a44c07cP1
MSG91_TEMPLATE_ID=6a44b25aeb01136f850ae507
MSG91_OTP_LENGTH=6
MSG91_OTP_EXPIRY_MIN=10

# SMTP for welcome email. Unset → mock (logged to console). Fill to send real mail.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="CONROY <no-reply@conroy.global>"

# Admin panel key — enter this at /admin/login. Change it to your own secret.
ADMIN_KEY=conroy-admin-2026

# Razorpay online payments (fill from Razorpay Dashboard → Settings → API Keys).
# Leave blank for free demo checkout. KEY_SECRET is server-side only.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio OTP (real SMS from the backend). Fill from Twilio Console.
# TWILIO_FROM must be a Twilio-OWNED number (your trial number), NOT a personal SIM.
# Or set TWILIO_MESSAGING_SERVICE_SID instead of TWILIO_FROM.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
TWILIO_MESSAGING_SERVICE_SID=

# WhatsApp Cloud API OTP (sends code on WhatsApp from your Business number — no DLT).
